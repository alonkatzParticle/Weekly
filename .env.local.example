# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it contains real credentials.

# ── Monday.com ────────────────────────────────────────────────────────────────
# Get from: Monday.com > Profile picture (top right) > Developers > API token
MONDAY_TOKEN=your_monday_api_token_here

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Dropbox ───────────────────────────────────────────────────────────────────
# Option A — Long-lived access token (simpler, expires after ~4 hours):
# Get from: https://www.dropbox.com/developers/apps > your app > Generate access token
DROPBOX_TOKEN=your_dropbox_access_token_here

# Option B — OAuth2 refresh token (recommended, never expires):
# Get from: https://www.dropbox.com/developers/apps > your app
DROPBOX_APP_KEY=your_app_key_here
DROPBOX_APP_SECRET=your_app_secret_here
DROPBOX_REFRESH_TOKEN=your_refresh_token_here

# Base folder path inside your Dropbox where weekly files are stored
DROPBOX_PATH=/Your/Dropbox/Folder/Path/

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: leave POSTGRES_URL unset — the app uses SQLite automatically (weekly-report.db)
# Production (Vercel): set this to your Vercel Postgres connection string
# POSTGRES_URL=postgresql://user:password@host:5432/dbname
